<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <style>
    body { font-family: Arial, sans-serif; color: #333; background: #f9f9f9; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
    .header { background: #cf6f94; color: #fff; padding: 28px 32px; }
    .header h1 { margin: 0; font-size: 1.5rem; }
    .body { padding: 28px 32px; }
    .row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f0f0f0; }
    .label { color: #888; font-size: 0.85rem; }
    .value { font-weight: 600; font-size: 0.95rem; }
    .items-table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    .items-table th { text-align: left; font-size: 0.8rem; color: #888; padding: 6px 0; border-bottom: 2px solid #f0f0f0; }
    .items-table td { padding: 8px 0; border-bottom: 1px solid #f0f0f0; font-size: 0.9rem; }
    .total { font-size: 1.2rem; font-weight: 700; color: #cf6f94; margin-top: 20px; text-align: right; }
    .footer { padding: 16px 32px; background: #fafafa; font-size: 0.78rem; color: #aaa; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🌸 Yeni Sifariş #{{order.code}}</h1>
    </div>
    <div class="body">
      <div class="row"><span class="label">Müştəri</span><span class="value">{{order.customerName}}</span></div>
      <div class="row"><span class="label">Telefon</span><span class="value">{{order.customerPhone}}</span></div>
      <div class="row"><span class="label">Ünvan</span><span class="value">{{order.address}}</span></div>
      {{#if order.note}}<div class="row"><span class="label">Qeyd</span><span class="value">{{order.note}}</span></div>{{/if}}
      <div class="row"><span class="label">Ödəniş</span><span class="value">{{order.paymentType}}</span></div>

      <table class="items-table">
        <thead>
          <tr>
            <th>Məhsul</th>
            <th>Say</th>
            <th>Qiymət</th>
          </tr>
        </thead>
        <tbody>
          {{#each order.items}}
          <tr>
            <td>{{this.product.name}}</td>
            <td>{{this.quantity}}</td>
            <td>{{this.price}} ₼</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="total">Cəmi: {{order.total}} ₼</div>
    </div>
    <div class="footer">Baku Roses · bakuroses.az</div>
  </div>
</body>
</html>
